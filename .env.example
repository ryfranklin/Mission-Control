# Copy to .env for local dev:  cp .env.example .env
# Postgres for LangGraph durable state (docker-compose.yml). Local-dev creds only.
POSTGRES_USER=mc
POSTGRES_PASSWORD=mc
POSTGRES_DB=mission_control
POSTGRES_PORT=5432

# LangGraph PostgresSaver connection string (consumed by the checkpointer in L2).
MC_POSTGRES_URL=postgresql://mc:mc@localhost:5432/mission_control?sslmode=disable
