# Mission Control — env file contract (TEMPLATE).
#
# The SINGLE source of runtime config for both the service and the Slack bridge. Copy to
# a path OUTSIDE the repo (e.g. ~/.mission-control/mc.env), fill in real values, and
# `chmod 600` it — it holds SECRETS (Slack tokens). wrapper.sh sources it with `set -a`,
# so every uncommented KEY=VALUE below is exported. Keep it repo-agnostic: no workspace
# names or tokens ever land in the repo; they live only here.
#
# Lines are plain `KEY=VALUE` (no `export`, no shell expansion). Placeholders are marked
# __LIKE_THIS__ — replace them.

# ---- Postgres (durable state; from docker-compose) ------------------------
# The service's checkpointer + runs/notifications outbox. Must match docker-compose.yml.
MC_POSTGRES_URL=postgresql://mc:mc@127.0.0.1:5432/mission_control?sslmode=disable

# ---- service ---------------------------------------------------------------
# MC_SERVICE_PORT=8000            # optional; loopback bind is fixed to 127.0.0.1
# MC_SERVICE_SDK=1                # optional; "1" = real SdkWorker (real $). Unset = StubWorker.
# MC_WORKER_MODEL=claude-opus-4-8 # optional; overrides the service build-worker model

# ---- API auth (SECRET) -----------------------------------------------------
# Bearer token gating the MUTATING run endpoints (approve/reject/scrub/cancel), so a
# gate decision needs an authenticated principal even off the Slack surface. UNSET =
# open (the backward-compatible localhost/dev posture); SET = those endpoints require
# `Authorization: Bearer <this>`. Reads (GET) stay open. The SAME var is read by the
# Slack bridge, which sends it on every request — keep them identical.
# MC_API_TOKEN=__REPLACE_WITH_A_LONG_RANDOM_STRING__   # e.g. `openssl rand -hex 32`

# ---- Slack: non-secret registry + the fleet default profile ----------------
# Path to the NON-SECRET registry JSON (profile names, channels, approvers, and the
# token ENV-VAR NAMES — never token values). Lives outside the repo too.
MC_SLACK_REGISTRY=__HOME__/.mission-control/slack_registry.json
# Optional: launches that don't name a profile inherit this one (must exist in the
# registry). Unset = opt-in (runs stay silent). The NAME is config, never hardcoded.
# MC_DEFAULT_SLACK_PROFILE=__PROFILE_NAME__

# ---- Slack bridge ----------------------------------------------------------
MC_SERVICE_URL=http://127.0.0.1:8000     # the seam the bridge polls (match the service bind)
# MC_SLACK_CURSOR=__HOME__/.mission-control/slack-cursor   # optional; durable consume cursor
# MC_LOG_LEVEL=INFO                       # optional

# ---- Slack tokens (SECRETS) ------------------------------------------------
# One bot (xoxb-) + one app-level (xapp-) token PER profile. The VARIABLE NAMES here must
# match the `token_env` / `app_token_env` your registry declares for each profile — the
# names are config; only the values are secret. Example for a profile whose registry entry
# says {"token_env": "__PROFILE_BOT_ENV__", "app_token_env": "__PROFILE_APP_ENV__"}:
# __PROFILE_BOT_ENV__=xoxb-__REPLACE_ME__
# __PROFILE_APP_ENV__=xapp-__REPLACE_ME__

# ---- optional cost/budget alerts (default off) -----------------------------
# MC_COST_ALERT_PER_RUN=1.00       # $ per-run reconciled-cost threshold
# MC_COST_ALERT_BUDGET=25.00       # $ rolling-window budget (per target)
# MC_COST_ALERT_WINDOW_HOURS=24    # window length
